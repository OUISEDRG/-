page {
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: #F5F5F5;
  box-sizing: border-box;
}

view, text, image, button, input {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: none;
  line-height: inherit;
  font-size: inherit;
}

button::after {
  border: none;
}
