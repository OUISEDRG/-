.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 580rpx;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.8);
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
}

.modal-content.show {
  transform: scale(1);
}

.modal-header {
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  padding: 24rpx 32rpx;
  overflow-y: auto;
  flex: 1;
  max-height: calc(70vh - 120rpx);
}

.modal-footer {
  display: flex;
  padding: 20rpx 32rpx 32rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.confirm {
  background: #E74C3C;
  color: #FFFFFF;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666;
}
