.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 580rpx;
  max-height: 70vh;
  background: #FFFEF9;
  border-radius: 32rpx;
  overflow: hidden;
  transform: scale(0.8);
  opacity: 0;
  transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  display: flex;
  flex-direction: column;
  box-shadow:
    0 12rpx 0 rgba(0,0,0,0.08),
    0 24rpx 60rpx rgba(0,0,0,0.2);
}

.modal-content.show {
  transform: scale(1);
  opacity: 1;
}

.modal-header {
  padding: 36rpx 32rpx 12rpx;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF6D00;
}

.modal-body {
  padding: 20rpx 32rpx 28rpx;
  overflow-y: auto;
  flex: 1;
  max-height: calc(70vh - 120rpx);
}

.modal-content-text {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.8;
  text-align: center;
  white-space: pre-line;
  display: block;
  font-weight: 500;
}

.modal-footer {
  display: flex;
  padding: 16rpx 32rpx 32rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  transition: all 0.15s;
  position: relative;
  box-shadow:
    inset 0 3rpx 0 rgba(255,255,255,0.4),
    0 6rpx 0 rgba(0,0,0,0.15),
    0 8rpx 12rpx rgba(0,0,0,0.08);
}

.modal-btn:active {
  transform: translateY(6rpx);
  box-shadow:
    inset 0 3rpx 0 rgba(255,255,255,0.3),
    0 0 0 rgba(0,0,0,0.15),
    0 2rpx 4rpx rgba(0,0,0,0.08);
}

.modal-btn.confirm {
  background: linear-gradient(180deg, #FFAB91 0%, #E64A19 100%);
  color: #FFF;
  text-shadow: 0 2rpx 0 rgba(0,0,0,0.15);
}

.modal-btn.cancel {
  background: linear-gradient(180deg, #EEEEEE 0%, #BDBDBD 100%);
  color: #5D4037;
}