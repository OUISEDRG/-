/* ==========================================
   大富翁 - 马卡龙潮玩风 UI
   ========================================== */

.game-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.board-scene {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx auto;
}

.board {
  position: relative;
  background: linear-gradient(145deg, #e8ecf1, #d5dce6);
  border-radius: 24rpx;
  box-shadow:
    0 8rpx 40rpx rgba(0,0,0,0.08),
    inset 0 2rpx 0 rgba(255,255,255,0.6);
}

.cell {
  position: absolute;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
  transform: translate(-50%, -50%);
}

.cell-color-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  border-radius: 12rpx 12rpx 0 0;
}
.cell-property .cell-color-bar {
  height: 10rpx;
}

.cell-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rpx;
  width: 100%;
}
.cell-name {
  font-size: 18rpx;
  font-weight: 600;
  color: #4a5568;
  text-align: center;
  line-height: 1.2;
}
.corner-name {
  font-size: 22rpx;
  font-weight: 700;
  color: #2d3748;
}
.cell-icon {
  font-size: 24rpx;
  margin: 2rpx 0;
}
.cell-price {
  font-size: 16rpx;
  color: #a0aec0;
  font-weight: 500;
}

.cell-start { background: #fff5f5; }
.cell-corner { background: #f7fafc; }
.cell-chance { background: #fffff0; }
.cell-fortune { background: #f0f9ff; }
.cell-tax { background: #fff5f0; }

.house-dots {
  position: absolute;
  bottom: 2rpx;
  display: flex;
  gap: 1rpx;
}
.house-dot {
  font-size: 14rpx;
  line-height: 1;
}

.owner-dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.8);
}

.board-center {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}
.center-glass {
  width: 90%;
  height: 90%;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.center-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #FF6B9D;
  letter-spacing: 4rpx;
}
.round-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #F59E0B;
}
.turn-text {
  font-size: 22rpx;
  color: #718096;
  font-weight: 500;
}
.dice-wrapper {
  margin-top: 8rpx;
}

.player-token {
  position: absolute;
  z-index: 20;
  pointer-events: none;
  transition: left 0.4s ease, top 0.4s ease;
}
.token-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 3rpx solid rgba(255,255,255,0.9);
}
.token-current .token-avatar {
  transform: scale(1.3);
}

.token-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 50rpx;
  height: 50rpx;
  margin-left: -25rpx;
  margin-top: -25rpx;
  border-radius: 50%;
  background: rgba(255,107,157,0.3);
  z-index: 1;
}

.floating-text-layer {
  position: fixed;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 100;
  pointer-events: none;
}
.floating-text {
  font-size: 48rpx;
  font-weight: 900;
  animation: floatUp 1.5s ease-out forwards;
}
@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-120rpx); }
}

.status-bar {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  width: 100%;
  max-width: 520px;
  box-sizing: border-box;
  overflow-x: auto;
}
.status-item {
  flex: 1;
  min-width: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 8rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.status-item.current {
  background: #FF6B9D;
  box-shadow: 0 4rpx 16rpx rgba(255,107,157,0.3);
}
.status-item.current .status-name,
.status-item.current .status-money { color: #FFF; }
.status-item.bankrupt { opacity: 0.35; }

.status-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  position: relative;
}
.status-ai-badge {
  position: absolute;
  bottom: -4rpx;
  right: -6rpx;
  font-size: 16rpx;
  background: #7C3AED;
  color: #FFF;
  border-radius: 6rpx;
  padding: 0 4rpx;
  line-height: 1.2;
}
.status-name {
  font-size: 20rpx;
  color: #4a5568;
  font-weight: 600;
}
.status-money {
  font-size: 18rpx;
  color: #a0aec0;
  font-weight: 500;
}

.waiting-bar {
  text-align: center;
  padding: 12rpx 24rpx;
  margin: 4rpx 16rpx;
  background: rgba(124,58,237,0.08);
  border-radius: 16rpx;
}
.waiting-text {
  font-size: 24rpx;
  color: #7C3AED;
  font-weight: 500;
}

.action-bar {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  width: 100%;
  max-width: 520px;
  box-sizing: border-box;
}
.safe-bottom {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.btn-jelly {
  position: relative;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  border: none;
  border-radius: 20rpx;
  color: #FFF;
  letter-spacing: 2rpx;
  line-height: 1;
}

.btn-icon { font-size: 26rpx; }

.btn-buy { background: #56ab91; }
.btn-build { background: #e07a6d; }
.btn-bank { background: #5b9aa5; }
.btn-assets { background: #9b6dcd; }
.btn-item { background: #e8a87c; }
.btn-shop { background: #d4941a; }
.btn-end { background: #8e9eab; }

.prop-float {
  position: fixed;
  bottom: 200rpx;
  left: 20rpx;
  right: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  z-index: 100;
}
.prop-float-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.1);
}
.pfi-icon { font-size: 36rpx; }
.pfi-name { font-size: 24rpx; font-weight: 600; color: #4a5568; }
.pfi-price { font-size: 22rpx; color: #F59E0B; font-weight: 600; }

.menu-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.menu-overlay.show {
  opacity: 1;
  pointer-events: auto;
}
.menu-panel {
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 340rpx;
  background: rgba(255,255,255,0.95);
  padding: 40rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.menu-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #FF6B9D;
  margin-bottom: 16rpx;
}
.menu-item {
  padding: 16rpx 20rpx;
  background: #f7fafc;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #4a5568;
}
.menu-item.danger { color: #E53E3E; }
.menu-close {
  margin-top: 20rpx;
  background: #e2e8f0;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 12rpx;
}
