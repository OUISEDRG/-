/* 页面基础布局 */
.game-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f2f2f2;
  overflow: hidden;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0;
  background-color: #fff;
  box-shadow: 0 2px 5px rgba(0,0,0,0.05);
  z-index: 10;
}
.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar {
  font-size: 40rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}
.avatar.active {
  transform: scale(1.2);
  box-shadow: 0 0 10rpx rgba(0,0,0,0.2);
}
.money {
  font-size: 20rpx;
  margin-top: 4rpx;
  color: #333;
}

/* 棋盘包裹层 */
.board-wrapper {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}

/* 棋盘主体（相对定位基准） */
.board {
  position: relative;
  background-color: #e0e0e0;
  border-radius: 12rpx;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
  overflow: hidden;
}

/* ★ 核心：格子的绝对定位机制 ★ */
.cell {
  position: absolute;
  box-sizing: border-box;
  background-color: #fff;
  border: 1px solid #ccc;
  display: flex;
  flex-direction: column;
}

/* 领地色条 */
.cell-header {
  width: 100%;
  height: 25%;
  min-height: 8rpx;
  border-bottom: 1px solid rgba(0,0,0,0.1);
}

/* 格子内部文字区 */
.cell-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
}
.cell-name {
  font-size: 22rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
}
.cell-price {
  font-size: 18rpx;
  color: #666;
  margin-top: 2rpx;
}
.cell-icon {
  font-size: 28rpx;
}

/* 房屋等级指示器 */
.house-level {
  position: absolute;
  top: 28%;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  font-size: 16rpx;
}

/* 停留的玩家头像 */
.players-on-cell {
  position: absolute;
  bottom: 4rpx;
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
}
.player-avatar {
  font-size: 24rpx;
  margin: 0 -2rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 50%;
}

/* 领地边框高亮（被购买后） */
.owner-border {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border: 4rpx solid transparent;
  pointer-events: none;
}

/* 棋盘中心的广场 */
.board-center {
  position: absolute;
  box-sizing: border-box;
  background-color: #f7f9fc;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: inset 0 0 20rpx rgba(0,0,0,0.05);
}
.center-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.round-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #4a5568;
}
.turn-text {
  font-size: 24rpx;
  color: #718096;
  margin: 10rpx 0 20rpx 0;
}
.dice-wrapper {
  transform: scale(1.5);
  margin-top: 20rpx;
}

/* 底部操作区 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 10rpx 40rpx 10rpx;
  background-color: #fff;
  border-top: 1px solid #eee;
}
.btn {
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-weight: bold;
  flex: 1;
  margin: 0 10rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}
.btn-bank { background: #e2e8f0; color: #4a5568; }
.btn-props { background: #bee3f8; color: #2b6cb0; }
.btn-buy { background: #fefcbf; color: #b7791f; }
.btn-build { background: #c6f6d5; color: #2f855a; }
.btn-end { background: #fed7d7; color: #c53030; }
