.game-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  padding: 0 0 30rpx;
  position: relative;
}

.game-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(0,0,0,0.3);
}

.header-left, .header-right {
  flex: 0 0 auto;
}

.header-center {
  flex: 1;
  text-align: center;
}

.round-text {
  font-size: 24rpx;
  color: #FFD700;
}

.turn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.menu-btn {
  font-size: 40rpx;
  color: #FFFFFF;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.1);
  border-radius: 12rpx;
}

.board-container {
  position: relative;
  margin: 16rpx auto;
  background: rgba(255,255,255,0.05);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.cell {
  position: absolute;
  padding: 1px;
}

.cell-inner {
  width: 100%;
  height: 100%;
  border-radius: 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255,255,255,0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
}

.cell:active .cell-inner {
  transform: scale(0.95);
}

.cell.property .cell-inner {
  border-width: 2rpx;
}

.cell-icon {
  font-size: 20rpx;
  line-height: 1;
}

.cell-name {
  font-size: 16rpx;
  color: #333;
  text-align: center;
  line-height: 1.2;
  margin-top: 1px;
  font-weight: 500;
}

.cell-price {
  font-size: 14rpx;
  color: #E74C3C;
  line-height: 1;
  margin-top: 1px;
}

.cell-players {
  position: absolute;
  bottom: 1px;
  right: 1px;
  display: flex;
  gap: 1px;
}

.cell-player-token {
  font-size: 14rpx;
  line-height: 1;
}

.cell-level-dots {
  position: absolute;
  top: 1px;
  right: 1px;
  display: flex;
  gap: 1px;
}

.level-dot {
  font-size: 10rpx;
  color: #E74C3C;
  line-height: 1;
}

.cell-owner-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  border-radius: 2rpx 2rpx 0 0;
}

.cell.start .cell-inner {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
}

.cell.corner .cell-inner {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.cell.chance .cell-inner {
  background: linear-gradient(135deg, #FFE66D, #FFD93D);
}

.cell.fortune .cell-inner {
  background: linear-gradient(135deg, #A8D8EA, #AA96DA);
}

.cell.tax .cell-inner {
  background: linear-gradient(135deg, #F38181, #F54E4E);
}

.cell.property .cell-inner {
  background: #FFFFFF;
}

.board-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.center-logo {
  font-size: 60rpx;
  line-height: 1;
}

.center-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 6rpx;
  letter-spacing: 4rpx;
}

.dice-area {
  display: flex;
  justify-content: center;
  padding: 10rpx 0;
  flex-shrink: 0;
}

.players-panel {
  padding: 0 20rpx;
  flex-shrink: 0;
}

.action-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  justify-content: center;
  flex-shrink: 0;
}

.action-btn {
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
  min-width: 120rpx;
  text-align: center;
}

.action-btn.buy {
  background: linear-gradient(135deg, #4ECDC4, #44B09E);
}

.action-btn.build {
  background: linear-gradient(135deg, #FFB347, #FF8E53);
}

.action-btn.bank {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.action-btn.props {
  background: linear-gradient(135deg, #A8D8EA, #AA96DA);
}

.action-btn.end-turn {
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
}

.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  justify-content: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.menu-overlay.show {
  opacity: 1;
  visibility: visible;
}

.menu-panel {
  width: 400rpx;
  background: #FFFFFF;
  height: 100vh;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s;
}

.menu-overlay.show .menu-panel {
  transform: translateX(0);
}

.menu-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

.menu-item {
  font-size: 32rpx;
  color: #333;
  padding: 28rpx 20rpx;
  border-bottom: 1px solid #F0F0F0;
  display: flex;
  align-items: center;
}

.menu-item.danger {
  color: #E74C3C;
}

.menu-close {
  margin-top: auto;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  text-align: center;
}

.modal-body-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  text-align: center;
}
