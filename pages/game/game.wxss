.game-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  overflow: hidden;
  position: relative;
}
.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 24rpx;
  margin: 20rpx 30rpx 0;
  background: rgba(255,255,255,0.95);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  z-index: 20;
  position: relative;
}
.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border: 4rpx solid;
  background: #FFF;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
  transition: all 0.3s;
}
.avatar.active {
  border-width: 5rpx;
  box-shadow: 0 0 0 8rpx rgba(255,107,157,0.15), 0 0 24rpx rgba(255,107,157,0.25);
  animation: avatarPulse 2s ease-in-out infinite;
}
@keyframes avatarPulse {
  0%,100% { box-shadow: 0 0 0 6rpx rgba(255,107,157,0.15), 0 0 20rpx rgba(255,107,157,0.25); }
  50% { box-shadow: 0 0 0 12rpx rgba(255,107,157,0), 0 0 32rpx rgba(255,107,157,0.35); }
}
.money {
  font-size: 26rpx;
  color: #FF6B9D;
  margin-top: 6rpx;
  font-weight: 700;
}
.board-scene {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 10rpx;
  z-index: 10;
  position: relative;
  overflow: visible;
}
.board-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);
}
.board {
  position: relative;
  background: linear-gradient(135deg,#FFF8E1 0%,#FFECB3 100%);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.15), 0 4rpx 12rpx rgba(0,0,0,0.1);
  border: 6rpx solid #D7CCC8;
}
.cell {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
  border: 2rpx solid rgba(0,0,0,0.08);
  border-radius: 8rpx;
  background: #FFF;
  transition: all 0.2s ease;
  z-index: 1;
}
.cell:active {
  transform: scale(0.98);
  filter: brightness(0.95);
}
.cell-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 20%;
  border-radius: 6rpx 6rpx 0 0;
  z-index: 2;
}
.cell-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
  z-index: 3;
  width: 100%;
  text-align: center;
  margin-top: 8%;
}
.cell-name {
  font-weight: 700;
  font-size: 16rpx;
  color: #37474F;
  line-height: 1.3;
  word-break: keep-all;
}
.cell-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}
.cell-price {
  font-size: 14rpx;
  color: #795548;
  font-weight: 600;
  background: rgba(255,255,255,0.9);
  border-radius: 4rpx;
  padding: 2rpx 6rpx;
  margin-top: 4rpx;
}
.house-level {
  position: absolute;
  bottom: 8%;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 2rpx;
  font-size: 14rpx;
  z-index: 3;
}
.players-on-cell {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 2rpx;
  z-index: 5;
  flex-wrap: wrap;
  justify-content: center;
  max-width: 90%;
}
.player-avatar {
  font-size: 20rpx;
  filter: drop-shadow(0 2rpx 3rpx rgba(0,0,0,0.3));
  transition: transform 0.2s ease-out;
}
.player-avatar.jumping {
  animation: hopBounce 0.5s ease-out;
}
@keyframes hopBounce {
  0% { transform: translateY(0) scale(1); }
  30% { transform: translateY(-18rpx) scale(1.25); }
  50% { transform: translateY(-8rpx) scale(1.1); }
  70% { transform: translateY(-4rpx) scale(1.03); }
  100% { transform: translateY(0) scale(1); }
}
.owner-border {
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  border: 4rpx solid;
  border-radius: 6rpx;
  pointer-events: none;
  z-index: 4;
  opacity: 0.7;
}
.board-center {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at center,#FFF3E0 0%,#FFE0B2 100%);
  border-radius: 16rpx;
  box-shadow: inset 0 4rpx 12rpx rgba(0,0,0,0.08), inset 0 2rpx 4rpx rgba(255,255,255,0.9);
  border: 3rpx solid rgba(0,0,0,0.05);
}
.center-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  z-index: 1;
}
.round-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #FF5722;
  text-shadow: 0 2rpx 0 rgba(255,255,255,0.8);
}
.turn-text {
  font-size: 22rpx;
  color: #795548;
  font-weight: 600;
}
.dice-wrapper {
  margin-top: 10rpx;
}
.action-bar {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 20rpx 36rpx;
  flex-wrap: wrap;
  justify-content: center;
  z-index: 15;
  position: relative;
  background: rgba(255,255,255,0.9);
  border-top: 2rpx solid rgba(0,0,0,0.06);
}
.btn {
  padding: 20rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  transition: all 0.15s ease;
  flex: 1;
  min-width: 120rpx;
  max-width: 180rpx;
  text-align: center;
  color: #FFF;
  box-shadow: 0 6rpx 0 rgba(0,0,0,0.15), 0 8rpx 12rpx rgba(0,0,0,0.1);
  border: none;
}
.btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 rgba(0,0,0,0.15), 0 3rpx 4rpx rgba(0,0,0,0.1);
}
.btn-bank {
  background: linear-gradient(180deg,#4FC3F7 0%,#29B6F6 100%);
  box-shadow: 0 6rpx 0 #0288D1, 0 8rpx 12rpx rgba(0,0,0,0.1);
}
.btn-props {
  background: linear-gradient(180deg,#CE93D8 0%,#BA68C8 100%);
  box-shadow: 0 6rpx 0 #8E24AA, 0 8rpx 12rpx rgba(0,0,0,0.1);
}
.btn-buy {
  background: linear-gradient(180deg,#FFAB91 0%,#FF8A65 100%);
  box-shadow: 0 6rpx 0 #E64A19, 0 8rpx 12rpx rgba(0,0,0,0.1);
}
.btn-build {
  background: linear-gradient(180deg,#FFF176 0%,#FFEE58 100%);
  color: #5D4037;
  box-shadow: 0 6rpx 0 #F9A825, 0 8rpx 12rpx rgba(0,0,0,0.1);
}
.btn-end {
  background: linear-gradient(180deg,#B0BEC5 0%,#90A4AE 100%);
  box-shadow: 0 6rpx 0 #546E7A, 0 8rpx 12rpx rgba(0,0,0,0.1);
}
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 900;
  visibility: hidden;
  transition: all 0.3s ease;
}
.menu-overlay.show {
  background: rgba(0,0,0,0.45);
  visibility: visible;
}
.menu-panel {
  position: absolute;
  top: 0;
  right: -360rpx;
  width: 320rpx;
  height: 100%;
  background: rgba(255,255,255,0.96);
  padding: 48rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  transition: right 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
  box-shadow: -6rpx 0 30rpx rgba(0,0,0,0.15);
}
.menu-overlay.show .menu-panel {
  right: 0;
}
.menu-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF5722;
  margin-bottom: 24rpx;
  text-align: center;
}
.menu-item {
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #FFF;
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.07);
  transition: all 0.2s ease;
}
.menu-item:active {
  transform: scale(0.98);
  background: #F5F5F5;
}
.menu-item.danger {
  background: #FFEBEE;
  color: #E53935;
}
.menu-close {
  margin-top: auto;
  padding: 20rpx;
  text-align: center;
  background: #F5F5F5;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #757575;
  font-weight: 600;
  border: none;
}

/* 道具系统 */
.btn-item {
  background: linear-gradient(135deg, #A78BFA, #7C3AED);
  color: #FFF;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  margin: 0 4rpx;
}
.btn-shop {
  background: linear-gradient(135deg, #F59E0B, #D97706);
  color: #FFF;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  margin: 0 4rpx;
}
.prop-actions, .buy-prop-actions {
  position: fixed;
  bottom: 180rpx;
  left: 20rpx;
  right: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: center;
  z-index: 100;
}
.prop-action-item {
  background: rgba(255,255,255,0.95);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}
.prop-action-icon { font-size: 36rpx; }
.prop-action-name { font-size: 24rpx; color: #333; }
.waiting-bar {
  text-align: center;
  padding: 12rpx;
  background: rgba(124,58,237,0.1);
  margin: 8rpx 16rpx;
  border-radius: 12rpx;
}
.waiting-text { font-size: 26rpx; color: #7C3AED; }
