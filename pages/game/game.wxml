<view class="game-container">
  <!-- 顶部状态栏 (显示玩家状态) -->
  <view class="status-bar">
    <view class="status-item" wx:for="{{players}}" wx:key="id" style="opacity: {{item.isBankrupt ? 0.5 : 1}};">
      <view class="avatar {{item.isCurrent ? 'active' : ''}}" style="border-color: {{item.roleColor}};">
        {{item.avatar}}
      </view>
      <view class="money">{{item.displayMoney}}</view>
    </view>
  </view>

  <!-- 核心：大富翁棋盘渲染区 -->
  <view class="board-wrapper">
    <view class="board" style="width: {{boardSize}}px; height: {{boardSize}}px;">
      
      <!-- 循环渲染所有格子 -->
      <block wx:for="{{boardCells}}" wx:key="id">
        <view class="cell"
              style="width: {{cellSize}}px; height: {{cellSize}}px; left: {{item.x}}px; top: {{item.y}}px; background-color: {{item.bgColor}};"
              bindtap="onCellTap"
              data-cell-id="{{item.id}}">
          
          <!-- 1. 格子顶部色条 (用于区分地段) -->
          <view class="cell-header" wx:if="{{item.type === 'property'}}" style="background-color: {{item.color}};"></view>
          
          <!-- 2. 格子名称与图标 -->
          <view class="cell-content">
            <text class="cell-name">{{item.shortName}}</text>
            <text class="cell-icon" wx:if="{{item.icon && item.type !== 'property'}}">{{item.icon}}</text>
            <text class="cell-price" wx:if="{{item.displayPrice}}">{{item.displayPrice}}</text>
          </view>

          <!-- 3. 房屋等级指示器 -->
          <view class="house-level" wx:if="{{item.level > 0}}">
            <text wx:for="{{item.level}}" wx:key="*this">🏠</text>
          </view>

          <!-- 4. 停留在该格子的玩家头像 -->
          <view class="players-on-cell" wx:if="{{item.players && item.players.length > 0}}">
            <text class="player-avatar" wx:for="{{item.players}}" wx:key="*this" wx:for-item="avatar">{{avatar}}</text>
          </view>
          
          <!-- 5. 领地边框提示（如果有主人的话） -->
          <view class="owner-border" wx:if="{{item.ownerBorder}}" style="border-color: {{item.ownerBorder}};"></view>
        </view>
      </block>

      <!-- 棋盘中间的空地 (放回合数和骰子) -->
      <view class="board-center" style="width: {{centerSize}}px; height: {{centerSize}}px; left: {{cellSize}}px; top: {{cellSize}}px;">
        <view class="center-content">
          <text class="round-text">第 {{round}} 轮</text>
          <text class="turn-text">当前回合: {{currentPlayerName}}</text>
          <!-- 引用骰子组件 -->
          <view class="dice-wrapper">
             <dice disabled="{{diceDisabled}}" bindrollend="onDiceRollEnd"></dice>
          </view>
        </view>
      </view>
      
    </view>
  </view>

  <!-- 底部操作按钮栏 -->
  <view class="action-bar">
    <button class="btn btn-bank" wx:if="{{showBankBtn}}" bindtap="onBank">🏦 银行</button>
    <button class="btn btn-props" wx:if="{{showPropsBtn}}" bindtap="onViewProps">📋 资产</button>
    <button class="btn btn-buy" wx:if="{{showBuyBtn}}" bindtap="onBuyProperty">💰 买地</button>
    <button class="btn btn-build" wx:if="{{showBuildBtn}}" bindtap="onBuildHouse">🏠 盖房</button>
    <button class="btn btn-end" wx:if="{{showEndTurnBtn}}" bindtap="onEndTurn">⏭ 结束</button>
  </view>

  <!-- 全局弹窗模态框 -->
  <modal visible="{{modalVisible}}" title="{{modalTitle}}" content="{{modalContent}}"
         showConfirm="{{modalShowConfirm}}" showCancel="{{modalShowCancel}}"
         confirmText="{{modalConfirmText}}" cancelText="{{modalCancelText}}"
         bindconfirm="onModalConfirm" bindcancel="onModalCancel" />

  <!-- 菜单侧边栏 -->
  <view class="menu-overlay {{menuVisible ? 'show' : ''}}" bindtap="onCloseMenu">
    <view class="menu-panel" catchtap="stopPropagation">
      <text class="menu-title">游戏菜单</text>
      <view class="menu-item" bindtap="onSaveGame">💾 保存游戏</view>
      <view class="menu-item" bindtap="onLoadGame">📂 读取存档</view>
      <view class="menu-item" bindtap="onRules">📖 游戏规则</view>
      <view class="menu-item danger" bindtap="onQuitGame">🚪 退出游戏</view>
      <button class="menu-close" bindtap="onCloseMenu">关闭</button>
    </view>
  </view>
</view>
