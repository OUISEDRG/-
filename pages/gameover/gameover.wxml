<view class="container">
  <view class="celebration">
    <text class="trophy">🏆</text>
    <text class="congrats-text">恭喜获胜！</text>
  </view>

  <view class="winner-card">
    <view class="winner-avatar" style="background: {{bgColor || '#FFF5F5'}}">
      <text>{{winnerAvatar}}</text>
    </view>
    <text class="winner-name">{{winner}}</text>
    <view class="winner-stats">
      <view class="stat-item">
        <text class="stat-label">最终资金</text>
        <text class="stat-value">{{finalMoney}} 元</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">玩家总数</text>
        <text class="stat-value">{{totalPlayers}} 人</text>
      </view>
    </view>
  </view>

  <view class="actions">
    <button class="action-btn primary" bindtap="onPlayAgain">🔄 再来一局</button>
    <button class="action-btn secondary" bindtap="onBackHome">🏠 返回首页</button>
  </view>
</view>
