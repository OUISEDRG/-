.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 30%, #0f3460 60%, #1a1a2e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* 金色光效背景 */
.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(ellipse at center, rgba(255,215,0,0.08) 0%, transparent 70%);
  animation: rotateBg 20s linear infinite;
  pointer-events: none;
}

@keyframes rotateBg {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 撒花特效 */
.confetti-layer {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 999;
  overflow: hidden;
}

.confetti {
  position: absolute;
  top: -40rpx;
  width: 16rpx;
  height: 28rpx;
  border-radius: 4rpx;
  animation: confettiFall linear infinite;
}

.confetti.c1 { left: 5%; background: #FF6B6B; animation-duration: 3.5s; animation-delay: 0s; }
.confetti.c2 { left: 12%; background: #FCD34D; animation-duration: 4s; animation-delay: 0.3s; }
.confetti.c3 { left: 20%; background: #4ECDC4; animation-duration: 3s; animation-delay: 0.7s; }
.confetti.c4 { left: 28%; background: #C084FC; animation-duration: 4.5s; animation-delay: 0.1s; }
.confetti.c5 { left: 36%; background: #FF6B9D; animation-duration: 3.8s; animation-delay: 0.5s; }
.confetti.c6 { left: 44%; background: #FCD34D; animation-duration: 3.2s; animation-delay: 0.9s; }
.confetti.c7 { left: 52%; background: #4ECDC4; animation-duration: 4.2s; animation-delay: 0.2s; }
.confetti.c8 { left: 60%; background: #FF6B6B; animation-duration: 3.7s; animation-delay: 0.6s; }
.confetti.c9 { left: 68%; background: #C084FC; animation-duration: 4s; animation-delay: 0.4s; }
.confetti.c10 { left: 76%; background: #FF6B9D; animation-duration: 3.3s; animation-delay: 0.8s; }
.confetti.c11 { left: 84%; background: #FCD34D; animation-duration: 4.1s; animation-delay: 1s; }
.confetti.c12 { left: 92%; background: #4ECDC4; animation-duration: 3.6s; animation-delay: 0.15s; }

@keyframes confettiFall {
  0% { transform: translateY(0) rotate(0deg) scale(1); opacity: 1; }
  50% { opacity: 0.8; }
  100% { transform: translateY(100vh) rotate(720deg) scale(0.5); opacity: 0; }
}

/* 皇冠 */
.crown-area {
  margin-bottom: 10rpx;
  animation: crownFloat 2s ease-in-out infinite;
  z-index: 1;
}

@keyframes crownFloat {
  0%,100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-15rpx) rotate(5deg); }
}

.crown-icon {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(255,215,0,0.6));
}

/* 祝贺区 */
.celebration {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  z-index: 1;
}

.trophy {
  font-size: 100rpx;
  line-height: 1;
  filter: drop-shadow(0 4rpx 16rpx rgba(255,215,0,0.5));
  animation: trophyBounce 2s ease-in-out infinite;
}

@keyframes trophyBounce {
  0%,100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.1); }
}

.congrats-text {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FFD700, #FFA500, #FFD700);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-top: 16rpx;
  filter: drop-shadow(0 2rpx 8rpx rgba(255,215,0,0.3));
}

/* 赢家卡片 */
.winner-card {
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 560rpx;
  border: 1rpx solid rgba(255,215,0,0.2);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.1);
  z-index: 1;
  animation: cardSlideUp 0.6s ease-out;
}

@keyframes cardSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.winner-avatar-wrap {
  position: relative;
  margin-bottom: 12rpx;
}

.winner-avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 68rpx;
  border: 4rpx solid rgba(255,215,0,0.5);
  box-shadow: 0 0 30rpx rgba(255,215,0,0.3);
}

.crown-badge {
  position: absolute;
  top: -22rpx;
  right: -10rpx;
  font-size: 44rpx;
  filter: drop-shadow(0 2rpx 6rpx rgba(0,0,0,0.3));
  animation: crownFloat 2s ease-in-out infinite;
}

.winner-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFD700;
  margin-bottom: 24rpx;
  text-shadow: 0 2rpx 8rpx rgba(255,215,0,0.3);
}

/* 数据统计网格 */
.stats-grid {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.stat-item {
  flex: 1 1 calc(50% - 6rpx);
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
  padding: 18rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.stat-item:last-child:nth-child(odd) {
  flex: 1 1 100%;
}

.stat-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFF;
}

.stat-value.gold {
  color: #FFD700;
  font-size: 30rpx;
}

/* 按钮 */
.actions {
  width: 100%;
  max-width: 560rpx;
  margin-top: 44rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  z-index: 1;
}

.action-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 40rpx;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.2s;
}

.action-btn:active { transform: scale(0.96); }

.btn-icon { font-size: 36rpx; }

.primary-btn {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #1a1a2e;
  box-shadow: 0 8rpx 28rpx rgba(255,215,0,0.35);
}

.home-btn {
  background: rgba(255,255,255,0.12);
  color: #FFF;
  border: 2rpx solid rgba(255,255,255,0.2);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}
