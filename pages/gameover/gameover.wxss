.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 50%, #FF8C00 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

.celebration {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.trophy {
  font-size: 160rpx;
  line-height: 1;
  animation: bounce 1s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30rpx); }
}

.congrats-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  margin-top: 20rpx;
}

.winner-card {
  background: rgba(255,255,255,0.95);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 500rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.winner-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.winner-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.winner-stats {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.stat-label {
  font-size: 28rpx;
  color: #999;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #E74C3C;
}

.actions {
  width: 100%;
  max-width: 500rpx;
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
}

.action-btn.primary {
  background: #FFFFFF;
  color: #E74C3C;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.action-btn.secondary {
  background: rgba(255,255,255,0.3);
  color: #FFFFFF;
  border: 2rpx solid rgba(255,255,255,0.5);
}
