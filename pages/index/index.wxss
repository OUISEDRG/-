.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
}

.header {
  flex: 0 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  font-size: 120rpx;
  line-height: 1.2;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.logo-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
  letter-spacing: 8rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  letter-spacing: 4rpx;
}

.menu-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
  padding: 20rpx 0;
}

.menu-card {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  transition: transform 0.2s;
  position: relative;
  overflow: hidden;
}

.menu-card:active {
  transform: scale(0.98);
}

.menu-card.disabled {
  opacity: 0.5;
}

.menu-card.disabled:active {
  transform: none;
}

.menu-icon {
  font-size: 56rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.4;
}

.menu-arrow {
  font-size: 48rpx;
  color: #CCC;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.new-game .menu-icon {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border-radius: 16rpx;
  color: white;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.continue-game .menu-icon {
  background: linear-gradient(135deg, #4ECDC4, #44B09E);
  border-radius: 16rpx;
  color: white;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rules .menu-icon {
  background: linear-gradient(135deg, #A8D8EA, #AA96DA);
  border-radius: 16rpx;
  color: white;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer {
  flex: 0 0 auto;
  text-align: center;
  padding: 30rpx 0 10rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  letter-spacing: 2rpx;
}
