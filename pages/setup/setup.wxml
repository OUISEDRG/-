<view class="container">
  <!-- 玩家数量选择 -->
  <view class="section">
    <view class="section-title">
      <text class="section-icon">👥</text>
      <text>选择玩家数量</text>
    </view>
    <view class="player-count-selector">
      <view
        class="count-option {{playerCount === 2 ? 'active' : ''}}"
        data-count="2"
        bindtap="onSelectPlayerCount"
      >
        <text class="count-num">2</text>
        <text class="count-label">人</text>
      </view>
      <view
        class="count-option {{playerCount === 3 ? 'active' : ''}}"
        data-count="3"
        bindtap="onSelectPlayerCount"
      >
        <text class="count-num">3</text>
        <text class="count-label">人</text>
      </view>
      <view
        class="count-option {{playerCount === 4 ? 'active' : ''}}"
        data-count="4"
        bindtap="onSelectPlayerCount"
      >
        <text class="count-num">4</text>
        <text class="count-label">人</text>
      </view>
    </view>
  </view>

  <!-- 角色选择 - Swiper 卡片 -->
  <view class="section">
    <view class="section-title">
      <text class="section-icon">🎁</text>
      <text>选择角色 ({{selectedCount}}/{{playerCount}})</text>
    </view>
    <swiper
      class="role-swiper"
      previous-margin="60rpx"
      next-margin="60rpx"
      current="{{swiperCurrent}}"
      bindchange="onSwiperChange"
    >
      <swiper-item wx:for="{{roles}}" wx:key="id">
        <view class="role-card {{item.selected ? 'selected' : ''}} {{item.disabled ? 'disabled' : ''}}"
              data-role="{{item.id}}"
              bindtap="onSelectRole">
          <view class="role-card-inner" style="background: linear-gradient(135deg, {{item.bgColor}}, #FFF);">
            <view class="role-avatar-wrap">
              <view class="role-avatar-ring {{item.selected ? 'pulse-ring' : ''}}" style="border-color: {{item.color}};">
                <view class="role-avatar" style="background: {{item.bgColor}};">
                  <text class="role-emoji">{{item.avatar}}</text>
                </view>
              </view>
            </view>
            <text class="role-name">{{item.name}}</text>
            <view class="role-skill-badge" style="background: {{item.color}};">
              <text class="skill-name">⚡ {{item.skill}}</text>
            </view>
            <text class="role-skill-desc">{{item.skillDesc}}</text>
            <view class="role-check-mark" wx:if="{{item.selected}}">
              <text>✓</text>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
    <view class="swiper-dots">
      <view class="dot {{swiperCurrent === index ? 'active' : ''}}" wx:for="{{roles}}" wx:key="id" wx:for-index="index"></view>
    </view>
  </view>

  <!-- 初始资金 - Slider -->
  <view class="section">
    <view class="section-title">
      <text class="section-icon">💰</text>
      <text>初始资金</text>
    </view>
    <view class="money-display">
      <text class="money-value">{{initialMoney / 10000}} 万</text>
      <text class="money-raw">{{initialMoney}} 元</text>
    </view>
    <slider
      class="money-slider"
      min="5000"
      max="30000"
      step="1000"
      value="{{initialMoney}}"
      activeColor="#FF6B9D"
      backgroundColor="#F0F0F0"
      block-size="24"
      bindchange="onMoneyChange"
    />
    <view class="money-range">
      <text>5千</text>
      <text>3万</text>
    </view>
  </view>

  <!-- 已选玩家列表 -->
  <view class="section" wx:if="{{selectedCount > 0}}">
    <view class="section-title">
      <text class="section-icon">🎮</text>
      <text>当前玩家</text>
    </view>
    <view class="player-list">
      <view class="player-item" wx:for="{{selectedRoles}}" wx:key="index">
        <text class="player-avatar">{{item.avatar}}</text>
        <text class="player-name">{{item.displayName}}</text>
        <text class="player-skill-tag" style="background: {{item.color}};">{{item.skill}}</text>
        <text class="player-remove" data-index="{{index}}" bindtap="onRemoveRole">✕</text>
      </view>
    </view>
  </view>

  <!-- AI玩家配置 -->
  <view class="section" wx:if="{{selectedCount > 0}}">
    <view class="section-title">
      <text class="section-icon">🤖</text>
      <text>AI 玩家设置</text>
    </view>
    <view class="ai-list">
      <view class="ai-item" wx:for="{{selectedRoles}}" wx:key="index">
        <text class="ai-player-name">{{item.avatar}} {{item.displayName}}</text>
        <view class="ai-toggle {{aiPlayers.indexOf(index) >= 0 ? 'active' : ''}}" data-index="{{index}}" bindtap="onToggleAI">
          <text>{{aiPlayers.indexOf(index) >= 0 ? '🤖 AI' : '👤 玩家'}}</text>
        </view>
      </view>
    </view>
    <view class="ai-difficulty" wx:if="{{aiPlayers.length > 0}}">
      <text class="ai-diff-label">AI难度：</text>
      <view class="diff-option {{aiDifficulty === 'easy' ? 'active' : ''}}" data-level="easy" bindtap="onAiDifficulty">
        <text>简单</text>
      </view>
      <view class="diff-option {{aiDifficulty === 'normal' ? 'active' : ''}}" data-level="normal" bindtap="onAiDifficulty">
        <text>普通</text>
      </view>
      <view class="diff-option {{aiDifficulty === 'hard' ? 'active' : ''}}" data-level="hard" bindtap="onAiDifficulty">
        <text>困难</text>
      </view>
    </view>
  </view>

  <!-- 开始按钮 -->
  <view class="start-btn-area">
    <button
      class="start-btn {{selectedCount === playerCount ? '' : 'disabled'}}"
      disabled="{{selectedCount !== playerCount}}"
      bindtap="onStartGame"
    >
      🎲 开始游戏
    </button>
  </view>
</view>
