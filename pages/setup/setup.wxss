.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 20rpx 30rpx 40rpx;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.section-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.player-count-selector {
  display: flex;
  gap: 20rpx;
}

.count-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.count-option.active {
  background: #FFF0F0;
  border-color: #E74C3C;
}

.count-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
}

.count-option.active .count-num {
  color: #E74C3C;
}

.count-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.money-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.money-option {
  flex: 1;
  min-width: calc(25% - 12rpx);
  text-align: center;
  padding: 20rpx 16rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.money-option.active {
  background: #FFF0F0;
  border-color: #E74C3C;
}

.money-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.money-option.active .money-amount {
  color: #E74C3C;
}

.role-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.role-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.2s;
}

.role-card.selected {
  background: #FFF0F0;
  border-color: #E74C3C;
}

.role-card.disabled {
  opacity: 0.4;
}

.role-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.role-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.role-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #E74C3C;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFF;
  font-size: 22rpx;
  font-weight: 700;
}

.player-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.player-item {
  display: flex;
  align-items: center;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.player-avatar {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.player-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.player-remove {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #E74C3C;
  border-radius: 50%;
  background: #FFF0F0;
}

.start-btn-area {
  margin-top: 20rpx;
  padding: 10rpx 0 30rpx;
}

.start-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #E74C3C, #C0392B);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 16rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.start-btn.disabled {
  background: #CCC;
  color: #999;
}
