.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40rpx 30rpx;
}

.room-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.room-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 8rpx;
}

.room-id {
  display: block;
  font-size: 80rpx;
  font-weight: 800;
  color: #FFD700;
  letter-spacing: 16rpx;
  text-shadow: 0 0 30rpx rgba(255,215,0,0.3);
}

.room-status {
  display: inline-block;
  margin-top: 12rpx;
  padding: 8rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-waiting { background: rgba(78,205,196,0.2); color: #4ECDC4; }
.status-playing { background: rgba(255,107,157,0.2); color: #FF6B9D; }

.player-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  margin-bottom: 20rpx;
  display: block;
}

.player-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.player-slot {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid rgba(255,255,255,0.08);
  min-height: 180rpx;
  justify-content: center;
}

.player-slot.filled {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,215,0,0.2);
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.player-name {
  font-size: 26rpx;
  color: #FFF;
  font-weight: 600;
}

.host-badge {
  font-size: 20rpx;
  color: #FFD700;
  background: rgba(255,215,0,0.15);
  padding: 2rpx 14rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
}

.empty-icon {
  font-size: 48rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  margin-top: 4rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.btn-start {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #1a1a2e;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 28rpx;
  text-align: center;
}

.wait-hint {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

.btn-leave {
  width: 100%;
  padding: 24rpx;
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.6);
  font-size: 28rpx;
  border-radius: 28rpx;
  text-align: center;
  margin-top: 20rpx;
}